# SyncWave signaling server — copy to `.env` and adjust per environment.
#
# Production checklist:
#   APP_ENV=production
#   PIN_HASH_SECRET=<long random secret>
#   REQUIRE_SERVER_CONNECTION_PIN=true
#   SERVER_CONNECTION_PIN=<unique 8-digit host PIN>
#   ALLOWED_ORIGINS=https://your-listener-domain.example
#   LOG_LEVEL=INFO
#   Terminate TLS at your reverse proxy (HTTPS/WSS).

# --- Application ---
APP_NAME=SyncWave Signaling Server
APP_VERSION=1.1.5
# Use `production` on public deployments; `development` for local debugging.
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
WEBSOCKET_PATH=/ws
PROTOCOL_VERSION=1
# Protect host/relay WebSocket handshakes on internet-facing servers.
REQUIRE_SERVER_CONNECTION_PIN=true
# Example only — replace before production (exactly 8 digits when required).
SERVER_CONNECTION_PIN=01234567
REDIS_URL=
ROOM_TTL_SECONDS=21600
MAX_PARTICIPANTS_PER_ROOM=20
# Required in production — used to hash room PINs.
PIN_HASH_SECRET=change-this-in-production
# Restrict to your listener page origin(s) in production when possible.
ALLOWED_ORIGINS=*
LOG_LEVEL=INFO
GITHUB_REDIRECT=https://github.com/OpenCodeQuark/syncwave

# --- Uvicorn (Dockerfile / Procfile / platform env) ---
# Shell startup passes these to `uvicorn`; listed here so Settings load succeeds.
FORWARDED_ALLOW_IPS=*
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=20
KEEP_ALIVE_TIMEOUT=10
